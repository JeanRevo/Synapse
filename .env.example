# OpenAI Configuration (Required for full functionality)
OPENAI_API_KEY=sk-proj-VOTRE_CLE_OPENAI_ICI
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Alternative: HuggingFace Embeddings (Free, but slower and no LLM by default)
USE_HUGGINGFACE_EMBEDDINGS=False
HUGGINGFACE_MODEL=sentence-transformers/all-MiniLM-L6-v2

# RAG Configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=4

# Vector Store (faiss or chromadb)
VECTOR_STORE_TYPE=faiss

# Application
DEBUG=False

# ML Features (Advanced Functionalities)
ENABLE_CLASSIFICATION=True
ENABLE_SUMMARIZATION=True
ENABLE_RECOMMENDATIONS=True
USE_ML_MODELS=False  # True for Transformer models (slower but better quality)
